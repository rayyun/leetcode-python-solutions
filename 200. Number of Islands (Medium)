# https://leetcode.com/problems/number-of-islands/description/

# Solution 1 - DFS (iteration)
# O(m * n) / O(m * n)
class Solution:
    def numIslands(self, grid: List[List[str]]) -> int:
        R = len(grid)
        C = len(grid[0])
        count = 0
        dirs = [(0, 1), (0, -1), (1, 0), (-1, 0)]

        for r in range(R):
            for c in range(C):
                if grid[r][c] == "1":
                    count += 1
                    stack = [(r, c)]

                    while stack:
                        nr, nc = stack.pop()

                        if 0 <= nr < R and 0 <= nc < C and grid[nr][nc] == "1":
                            grid[nr][nc] = "#"

                            for x, y in dirs:
                                stack.append((nr + x, nc + y))

        return count

    
    
# Solution 2 - DFS (recursion)
class Solution:
    def numIslands(self, grid: List[List[str]]) -> int:
        R, C = len(grid), len(grid[0])
        count = 0
        dirs = [(0, 1), (0, -1), (1, 0), (-1, 0)]
        
        def dfs(r, c):
            if 0 <= r < R and 0 <= c < C and grid[r][c] == "1":
                grid[r][c] = "#"

                for x, y in dirs:
                    dfs(r + x, c + y)

        
        for r in range(R):
            for c in range(C):
                if grid[r][c] == "1":
                    count += 1
                    dfs(r, c)

        return count
